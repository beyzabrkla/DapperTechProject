@model List<ResultPublisherDTO>
@{
    ViewData["Title"] = "Yayıncı Ağı";
    Layout = "~/Views/Shared/_Layout.cshtml";

    int totalCount = ViewBag.TotalCount ?? 0;
    int pageSize = ViewBag.PageSize ?? 12;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;

    // Gösterilen kayıt aralığını hesapla
    int startRecord = ((currentPage - 1) * pageSize) + 1;
    int endRecord = Math.Min(currentPage * pageSize, totalCount);
}

<div class="grid grid-cols-12 gap-md mb-xl">
</div>

<div class="bg-white border border-slate-200 shadow-sm overflow-hidden rounded-lg">
    <div class="px-lg py-md border-b border-slate-100 flex justify-between items-center bg-white">
        <div>
            <h3 class="text-lg font-bold text-[#332A1C]">Yayıncı Ağı Yönetimi</h3>
            <p class="text-[11px] text-slate-400 uppercase tracking-widest font-semibold">
                Toplam <span class="text-[#332A1C]">@totalCount</span> kayıttan
                <span class="text-[#332A1C]">@startRecord - @endRecord</span> arası gösteriliyor
            </p>
        </div>
        <div class="flex items-center gap-sm">
            <div class="flex flex-col gap-1">
                <label class="text-[10px] font-black text-stone-400 uppercase tracking-widest">Kategori Filtresi</label>
                <select onchange="location.href='?categoryId=' + this.value"
                        class="bg-slate-50 border border-slate-200 text-[#332A1C] text-xs font-bold rounded-md block w-64 p-2.5">
    
                    <option value="">Tüm Kategoriler</option>
    
                    @if (ViewBag.Categories != null)
                    {
                        foreach (var cat in ViewBag.Categories as List<ResultCategoryDTO>)
                        {
                            <option value="@cat.CategoryID" selected="@(ViewBag.SelectedCategory == cat.CategoryID)">
                                @cat.CategoryName.ToUpper()
                            </option>
                        }
                    }
                </select>
            </div>
            <a asp-action="CreatePublisher" class="flex items-center gap-2 bg-[#D4A373] text-[#332A1C] px-5 py-2.5 rounded text-[11px] font-black uppercase tracking-widest hover:bg-[#E9C46A] transition-all active:scale-95 shadow-md">
                <span class="material-symbols-outlined text-[18px]">add_circle</span> Yeni Yayıncı Ekle
            </a>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 border-b border-slate-200">
                    <th class="px-lg py-4 font-bold text-[10px] text-slate-500 uppercase tracking-widest">Yayıncı Platformu</th>
                    <th class="px-lg py-4 font-bold text-[10px] text-slate-500 uppercase tracking-widest text-center">Sektörel Kategori</th>
                    <th class="px-lg py-4 font-bold text-[10px] text-slate-500 uppercase tracking-widest text-right">Yönetim</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50/50 transition-colors group">
                        <td class="px-lg py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 rounded-lg bg-[#332A1C] flex items-center justify-center text-[#D4A373] font-black text-sm shadow-sm">
                                    @(string.IsNullOrEmpty(item.WebsiteURL) ? "P" : item.WebsiteURL.Substring(0, 1).ToUpper())
                                </div>
                                <div>
                                    <p class="font-bold text-slate-800 text-sm">@item.WebsiteURL</p>
                                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-tighter">Sistem ID: #@item.PublisherID</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-lg py-4 text-center">
                            <span class="px-3 py-1 rounded-full bg-[#D4A373]/10 text-[#332A1C] text-[10px] font-black uppercase border border-[#D4A373]/20">
                                @item.CategoryName
                            </span>
                        </td>
                        <td class="px-lg py-4 text-right">
                            <div class="flex justify-end gap-1">
                                <a asp-action="UpdatePublisher" asp-route-id="@item.PublisherID" class="p-2 text-slate-400 hover:text-[#332A1C] hover:bg-stone-100 rounded-md transition-all">
                                    <span class="material-symbols-outlined text-[20px]">edit_note</span>
                                </a>
                                <a asp-action="DeletePublisher" asp-route-id="@item.PublisherID" onclick="return confirm('Bu yayıncıyı ağdan çıkarmak istediğinize emin misiniz?')" class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md transition-all">
                                    <span class="material-symbols-outlined text-[20px]">delete_sweep</span>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="px-lg py-4 flex justify-between items-center border-t border-slate-100 bg-slate-50/50">
        <p class="text-[11px] text-slate-500 font-bold uppercase tracking-tight">Sayfa @currentPage / @totalPages</p>
    
        <div class="flex items-center gap-1">
            @if (currentPage > 1)
            {
                <a asp-action="PublisherList" asp-route-page="@(currentPage - 1)" asp-route-categoryId="@ViewBag.SelectedCategory" class="p-2 text-slate-600 bg-white border border-slate-200 rounded-md hover:bg-[#332A1C] hover:text-white transition-all shadow-sm">
                    <span class="material-symbols-outlined text-sm">chevron_left</span>
                </a>
            }

            <div class="flex gap-1 px-2">
                @{
                    int startPage = Math.Max(1, currentPage - 2);
                    int endPage = Math.Min(totalPages, currentPage + 2);
                }

                @if (startPage > 1)
                {
                    <a asp-action="PublisherList" asp-route-page="1" class="px-3 py-1.5 text-[11px] font-black rounded-md border bg-white text-slate-600 border-slate-200">1</a>
                    @if (startPage > 2)
                    {
                        <span class="px-1 text-slate-400">...</span>
                    }
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <a asp-action="PublisherList" asp-route-page="@i"
                           class="px-3 py-1.5 text-[11px] font-black rounded-md border transition-all @(currentPage == i ? "bg-[#332A1C] text-[#D4A373] border-[#332A1C]" : "bg-white text-slate-600 border-slate-200 hover:border-[#D4A373]")">
                        @i
                    </a>
                }

                @if (endPage < totalPages)
                {
                    @if (endPage < totalPages - 1)
                    {
                        <span class="px-1 text-slate-400">...</span>
                    }
                    <a asp-action="PublisherList" asp-route-page="@totalPages" asp-route-categoryId="@ViewBag.SelectedCategory"class ="px-3 py-1.5 text-[11px] font-black rounded-md border bg-white text-slate-600 border-slate-200">@totalPages</a>
                }
            </div>

            @if (currentPage < totalPages)
            {
                <a asp-action="PublisherList" asp-route-page="@(currentPage + 1)" class="p-2 text-slate-600 bg-white border border-slate-200 rounded-md hover:bg-[#332A1C] hover:text-white transition-all shadow-sm">
                    <span class="material-symbols-outlined text-sm">chevron_right</span>
                </a>
            }
        </div>
    </div>
</div>