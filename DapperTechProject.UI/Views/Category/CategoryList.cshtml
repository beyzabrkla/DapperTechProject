@model List<ResultCategoryDTO>
@{
    ViewData["Title"] = "Kategori Yönetimi";
    Layout = "_Layout";
}

<div class="flex justify-between items-end mb-lg">
    <div>
        <h2 class="font-h1 text-h1 text-primary">Kategori Yönetimi</h2>
        <p class="font-body-md text-on-surface-variant">Reklam segmentlerini sınıflandırın ve performanslarını izleyin.</p>
    </div>
    <a asp-action="CreateCategory" class="bg-[#332A1C] text-[#D4A373] px-md py-sm rounded-lg flex items-center gap-2 hover:bg-stone-800 transition-all shadow-sm">
        <span class="material-symbols-outlined text-[20px]">add_circle</span>
        <span class="font-body-md font-semibold text-[11px] uppercase tracking-widest">Yeni Kategori</span>
    </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-md mb-lg">
    <div class="bg-white border border-stone-100 p-md rounded-xl shadow-sm flex flex-col justify-between">
        <div>
            <span class="font-label-caps text-on-surface-variant uppercase text-[10px] font-bold">Toplam Kategori</span>
            <div class="flex items-baseline gap-2 mt-sm">
                <span class="font-h1 text-[32px] font-black text-[#332A1C]">@ViewBag.GrandTotal</span>
                <span class="text-green-600 text-[12px] font-bold">Aktif</span>
            </div>
        </div>
        <div class="mt-md pt-md border-t border-stone-50 flex items-center gap-2 text-stone-400">
            <span class="material-symbols-outlined text-[16px]">database</span>
            <span class="text-[10px] font-medium">Sistem veritabanından çekildi</span>
        </div>
    </div>
    
    <div class="bg-white border border-stone-100 p-md rounded-xl shadow-sm col-span-1 md:col-span-2 flex items-center justify-between overflow-hidden relative">
        <div class="z-10">
            <span class="font-label-caps text-on-surface-variant uppercase text-[10px] font-bold">En Çok Tercih Edilen</span>
            <div class="mt-sm">
                <span class="font-h1 text-[24px] text-[#332A1C] font-bold">@(Model.FirstOrDefault()?.CategoryName ?? "Veri Yok")</span>
                <p class="font-body-sm text-secondary mt-1">Ağdaki aktif yayıncıların odak noktası</p>
            </div>
        </div>
        <div class="z-10 bg-[#D4A373]/20 p-4 rounded-full mr-4">
            <span class="material-symbols-outlined text-[40px] text-[#332A1C]">trending_up</span>
        </div>
    </div>

    <div class="bg-[#332A1C] text-white p-md rounded-xl shadow-sm flex flex-col justify-center">
        <span class="font-label-caps text-[#D4A373] uppercase text-[10px] font-bold">Ağ Verimliliği</span>
        <span class="font-h1 text-[32px] mt-sm font-black">94.2%</span>
        <div class="w-full bg-white/10 h-1.5 rounded-full mt-md overflow-hidden">
            <div class="bg-[#D4A373] h-full w-[94.2%]"></div>
        </div>
    </div>
</div>

<div class="bg-white border border-stone-200 rounded-xl overflow-hidden shadow-sm">
    <table class="w-full text-left border-collapse">
        <thead class="bg-stone-50 border-b border-stone-200">
            <tr>
                <th class="px-md py-3 font-label-caps text-stone-500 uppercase text-[10px] tracking-widest">Kategori Bilgisi</th>
                <th class="px-md py-3 font-label-caps text-stone-500 uppercase text-[10px] tracking-widest">Durum Tanımı</th>
                <th class="px-md py-3 font-label-caps text-stone-500 uppercase text-center text-[10px] tracking-widest">Sistem Durumu</th>
                <th class="px-md py-3 font-label-caps text-stone-500 uppercase text-right text-[10px] tracking-widest">İşlemler</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-stone-100">
            @foreach (var item in Model)
            {
                <tr class="hover:bg-stone-50 transition-colors group">
                    <td class="px-md py-4">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg bg-[#332A1C] flex items-center justify-center text-[#D4A373]">
                                <span class="material-symbols-outlined text-[18px]">category</span>
                            </div>
                            <div>
                                <p class="font-bold text-[#332A1C] text-sm">@item.CategoryName.ToUpper()</p>
                                <p class="text-[10px] text-stone-400 font-bold">KOD: #CAT_@item.CategoryID</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-md py-4">
                        <p class="font-body-sm text-stone-600 text-xs">Bu kategoriye bağlı yayıncılar analiz edilebilir.</p>
                    </td>
                    <td class="px-md py-4 text-center">
                        <span class="px-3 py-1 bg-green-50 text-green-700 text-[10px] font-black uppercase rounded-full border border-green-100">Aktif</span>
                    </td>
                    <td class="px-md py-4 text-right">
                        <div class="flex items-center justify-end gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                            <a asp-action="UpdateCategory" asp-route-id="@item.CategoryID" class="p-2 hover:bg-stone-100 rounded-md text-stone-600 transition-all" title="Düzenle">
                                <span class="material-symbols-outlined text-[20px]">edit_note</span>
                            </a>
                            <a asp-action="DeleteCategory" asp-route-id="@item.CategoryID" onclick="return confirm('Bu kategoriyi silmek, bağlı yayıncıları etkileyebilir. Emin misiniz?')" class="p-2 hover:bg-red-50 rounded-md text-red-600 transition-all" title="Sil">
                                <span class="material-symbols-outlined text-[20px]">delete_sweep</span>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="p-md bg-stone-50 flex items-center justify-between border-t border-stone-200">
        <span class="font-body-sm text-stone-500">Toplam @ViewBag.TotalCount kayıt listeleniyor</span>
        <div class="flex items-center gap-2">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <a asp-action="CategoryList" asp-route-page="@i"
                       class="w-8 h-8 flex items-center justify-center rounded font-body-sm font-bold transition-all
                    @(i == ViewBag.CurrentPage ? "bg-[#332A1C] text-white" : "bg-white text-stone-600 border border-stone-200 hover:bg-stone-100")">
                    @i
                </a>
            }
        </div>
    </div>
</div>