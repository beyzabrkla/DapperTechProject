@model List<ResultCategoryDTO>
@{
    ViewData["Title"] = "Kategori Yönetimi";
    Layout = "_Layout";
}

<div class="flex justify-between items-end mb-lg">
    <div>
        <h2 class="font-h1 text-h1 text-primary">Kategori Yönetimi</h2>
        <p class="font-body-md text-on-surface-variant">Reklam segmentlerini sınıflandırın ve performanslarını izleyin.</p>
    </div>
    <div class="flex items-center gap-3">
        <div class="flex flex-col gap-1">
            <label class="text-[10px] font-black text-stone-400 uppercase tracking-widest pl-1">Durum Filtresi</label>
            <select onchange="window.location.href='?status=' + this.value"
                    class="bg-white border border-stone-200 text-[#332A1C] text-xs font-bold rounded-lg py-2 px-4 focus:ring-2 focus:ring-[#332A1C] outline-none shadow-sm">
                <option value="">TÜMÜ</option>
                <option value="true" selected="@(ViewBag.CurrentStatus?.ToString() == "True")">AKTİF</option>
                <option value="false" selected="@(ViewBag.CurrentStatus?.ToString() == "False")">PASİF</option>
            </select>
        </div>

        <a asp-action="CreateCategory" class="bg-[#332A1C] text-[#D4A373] px-md py-3 rounded-lg flex items-center gap-2 hover:bg-stone-800 transition-all shadow-md mt-auto">
            <span class="material-symbols-outlined text-[20px]">add_circle</span>
            <span class="font-body-md font-semibold text-[11px] uppercase tracking-widest">Yeni Kategori</span>
        </a>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-md mb-lg">
    <div class="bg-white border border-stone-100 p-md rounded-xl shadow-sm flex flex-col justify-between">
        <div>
            <span class="font-label-caps text-stone-400 uppercase text-[10px] font-black tracking-widest">Genel Envanter</span>
            <div class="flex items-baseline gap-2 mt-sm">
                <span class="font-h1 text-[32px] font-black text-[#332A1C]">@ViewBag.GrandTotal</span>
                <span class="text-stone-400 text-[11px] font-bold uppercase">Kategori</span>
            </div>
        </div>
        <div class="mt-md pt-md border-t border-stone-50 flex items-center gap-2 text-stone-400">
            <span class="material-symbols-outlined text-[16px]">inventory_2</span>
            <span class="text-[10px] font-medium uppercase tracking-tight">Tüm Kayıtlar Listelendi</span>
        </div>
    </div>
    
    <div class="bg-white border border-stone-100 p-md rounded-xl shadow-sm col-span-1 md:col-span-2 flex items-center justify-between overflow-hidden relative">
        <div class="z-10 px-2">
            <span class="font-label-caps text-stone-400 uppercase text-[10px] font-black tracking-widest">En Popüler Segment</span>
            <div class="mt-sm">
                <span class="font-h1 text-[26px] text-[#332A1C] font-black tracking-tight">@(Model.FirstOrDefault()?.CategoryName?.ToUpper() ?? "VERİ YOK")</span>
                <p class="font-body-sm text-stone-500 mt-1 text-[12px]">Reklam ağındaki yayıncıların en yoğun olduğu kategori.</p>
            </div>
        </div>
        <div class="z-10 bg-[#D4A373]/10 p-5 rounded-2xl mr-4 border border-[#D4A373]/20">
            <span class="material-symbols-outlined text-[42px] text-[#332A1C]">equalizer</span>
        </div>
        <div class="absolute -right-4 -bottom-4 opacity-[0.03] pointer-events-none">
            <span class="material-symbols-outlined text-[120px]">trending_up</span>
        </div>
    </div>

    <div class="bg-[#332A1C] text-white p-md rounded-xl shadow-lg flex flex-col justify-center border border-stone-800">
        <div class="flex justify-between items-start">
            <span class="font-label-caps text-[#D4A373] uppercase text-[10px] font-black tracking-widest">Aktif Durum</span>
            <div class="flex items-center gap-1">
                <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
                <span class="text-[9px] font-bold text-green-400 uppercase">Live</span>
            </div>
        </div>
        
        <div class="flex items-baseline gap-2 mt-sm">
            <span class="font-h1 text-[32px] font-black text-white">@ViewBag.ActiveCount</span>
            <span class="text-[11px] text-stone-500 font-bold">/ @ViewBag.GrandTotal</span>
        </div>

        <div class="w-full bg-white/5 h-2 rounded-full mt-md overflow-hidden border border-white/5">
            <div class="bg-[#D4A373] h-full shadow-[0_0_10px_rgba(212,163,115,0.4)] transition-all duration-1000"
                 style="width: @(ViewBag.GrandTotal > 0 ? (ViewBag.ActiveCount * 100 / ViewBag.GrandTotal) : 0)%">
            </div>
        </div>
        
        <div class="flex justify-between items-center mt-3">
            <span class="text-[9px] text-stone-400 font-bold uppercase tracking-tighter">Sistem Kapasitesi</span>
            <span class="text-[10px] text-[#D4A373] font-black">%@(ViewBag.GrandTotal > 0 ? (ViewBag.ActiveCount * 100 / ViewBag.GrandTotal) : 0)</span>
        </div>
    </div>
</div>

<div class="bg-white border border-stone-200 rounded-xl overflow-hidden shadow-sm">
    <table class="w-full text-left border-collapse">
        <thead class="bg-stone-50 border-b border-stone-200">
            <tr>
                <th class="px-md py-4 font-label-caps text-stone-500 uppercase text-[10px] tracking-widest">Kategori Bilgisi</th>
                <th class="px-md py-4 font-label-caps text-stone-500 uppercase text-[10px] tracking-widest">Açıklama</th>
                <th class="px-md py-4 font-label-caps text-stone-500 uppercase text-center text-[10px] tracking-widest">Durum</th>
                <th class="px-md py-4 font-label-caps text-stone-500 uppercase text-right text-[10px] tracking-widest">İşlemler</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-stone-100">
            @foreach (var item in Model)
            {
                <tr class="hover:bg-stone-50/80 transition-colors group">
                    <td class="px-md py-4">
                        <div class="flex items-center gap-3">
                            <div class="w-9 h-9 rounded-lg bg-[#332A1C] flex items-center justify-center text-[#D4A373] shadow-sm">
                                <span class="material-symbols-outlined text-[20px]">category</span>
                            </div>
                            <div>
                                <p class="font-bold text-[#332A1C] text-sm">@item.CategoryName.ToUpper()</p>
                                <p class="text-[9px] text-stone-400 font-black tracking-tighter">ID: #@item.CategoryID</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-md py-4">
                        <p class="text-stone-500 text-xs leading-relaxed">Bu segment altındaki yayıncılar için veri akışı @(item.Status ? "aktif" : "kapalı").</p>
                    </td>
                    <td class="px-md py-4 text-center">
                        @if (item.Status)
                        {
                            <span class="px-3 py-1 bg-green-50 text-green-700 text-[10px] font-black uppercase rounded-full border border-green-200 shadow-sm">Aktif</span>
                        }
                        else
                        {
                            <span class="px-3 py-1 bg-red-50 text-red-700 text-[10px] font-black uppercase rounded-full border border-red-200 shadow-sm">Pasif</span>
                        }
                    </td>
                    <td class="px-md py-4 text-right">
                        <div class="flex items-center justify-end gap-1 opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-x-2 group-hover:translate-x-0">
                            <a asp-action="UpdateCategory" asp-route-id="@item.CategoryID" class="p-2 hover:bg-stone-100 rounded-lg text-stone-600 transition-all" title="Düzenle">
                                <span class="material-symbols-outlined text-[20px]">edit_square</span>
                            </a>
                            <a asp-action="DeleteCategory" asp-route-id="@item.CategoryID" onclick="return confirm('Uyarı: Bu işlem geri alınamaz. Devam edilsin mi?')" class="p-2 hover:bg-red-50 rounded-lg text-red-600 transition-all" title="Sil">
                                <span class="material-symbols-outlined text-[20px]">delete</span>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="p-md bg-stone-50 flex items-center justify-between border-t border-stone-200">
        <span class="font-body-sm text-stone-500 text-xs font-medium">
            Gösterilen: <span class="text-[#332A1C] font-bold">@Model.Count</span> / Toplam: <span class="text-[#332A1C] font-bold">@ViewBag.TotalCount</span>
        </span>
        
        <div class="flex items-center gap-1.5">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <a asp-action="CategoryList"
                       asp-route-page="@i"
                       asp-route-status="@ViewBag.CurrentStatus"
                       class="min-w-[32px] h-8 flex items-center justify-center rounded-lg font-bold text-[11px] transition-all
                    @(i == ViewBag.CurrentPage ? "bg-[#332A1C] text-white shadow-md" : "bg-white text-stone-600 border border-stone-200 hover:border-[#332A1C] hover:text-[#332A1C]")">
                    @i
                </a>
            }
        </div>
    </div>
</div>