@model List<ResultAdImpressionDTO>

@{
    ViewData["Title"] = "Reklam Gösterimleri";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="bg-white border border-slate-200 shadow-sm overflow-hidden rounded-lg">
    
    <div class="p-lg border-b border-slate-100 bg-slate-50/30">
        <form method="get" action="@Url.Action("AdImpressionList")" class="flex flex-wrap items-center gap-4">
            
            <div class="flex flex-col gap-1">
                <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Kampanya</label>
                <select name="campaignId" class="py-2 px-4 text-xs border-slate-200 rounded-md outline-none bg-white shadow-sm min-w-[180px]">
                    <option value="">Tüm Kampanyalar</option>
                    @foreach (var c in ViewBag.Campaigns)
                    {
                        <option value="@c.CampaignID" selected="@(ViewBag.SelectedCampaign == c.CampaignID)">@c.CampaignName</option>
                    }
                </select>
            </div>

            <div class="flex flex-col gap-1">
                <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Yayıncı</label>
                <select name="publisherId" class="py-2 px-4 text-xs border-slate-200 rounded-md outline-none bg-white shadow-sm min-w-[180px]">
                    <option value="">Tüm Yayıncılar</option>
                    @foreach (var p in ViewBag.Publishers)
                    {
                        <option value="@p.PublisherID" selected="@(ViewBag.SelectedPublisher == p.PublisherID)">@p.WebsiteURL</option>
                    }
                </select>
            </div>

            <div class="flex flex-col gap-1">
                <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Bölge</label>
                <select name="regionId" class="py-2 px-4 text-xs border-slate-200 rounded-md outline-none bg-white shadow-sm min-w-[120px]">
                    <option value="">Tüm Bölgeler</option>
                    @foreach (var r in ViewBag.Regions)
                    {
                        <option value="@r.RegionID" selected="@(ViewBag.SelectedRegion == r.RegionID)">@r.RegionName</option>
                    }
                </select>
            </div>

            <div class="flex flex-col gap-1">
                <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Durum</label>
                <select name="isClicked" class="py-2 px-4 text-xs border-slate-200 rounded-md outline-none bg-white shadow-sm">
                    <option value="">Hepsi</option>
                    <option value="true" selected="@(ViewBag.SelectedStatus == true)">Sadece Tıklama</option>
                    <option value="false" selected="@(ViewBag.SelectedStatus == false)">Sadece Gösterim</option>
                </select>
            </div>
            
            <div class="flex items-end gap-3 h-full pt-5">
                <button type="submit" class="bg-[#332A1C] text-white px-6 py-2 rounded-md text-[11px] font-bold uppercase shadow-md flex items-center gap-2 transition-all hover:bg-stone-800">
                    <span class="material-symbols-outlined text-sm">search</span> Sorgula
                </button>

                @if (ViewBag.SelectedRegion != null || ViewBag.SelectedStatus != null || ViewBag.SelectedCampaign != null || ViewBag.SelectedPublisher != null)
                {
                    <div class="flex items-center bg-amber-50 border border-amber-100 px-3 py-1.5 rounded-md">
                        <span class="text-[10px] font-bold text-amber-800 uppercase italic">
                            Filtrelendi: @ViewBag.TotalCount.ToString("N0") Kayıt
                        </span>
                    </div>
                }
            </div>
        </form>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-slate-50 border-b border-slate-100">
                <tr>
                    <th class="px-lg py-3 text-[10px] font-bold text-slate-500 uppercase tracking-wider">Zaman & Log</th>
                    <th class="px-lg py-3 text-[10px] font-bold text-slate-500 uppercase tracking-wider">Kampanya & Yayıncı</th>
                    <th class="px-lg py-3 text-[10px] font-bold text-slate-500 uppercase tracking-wider text-center">Bölge</th>
                    <th class="px-lg py-3 text-[10px] font-bold text-slate-500 uppercase tracking-wider text-right">Maliyet & Durum</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50/50 transition-colors group">
                        <td class="px-lg py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-2 h-2 rounded-full @(item.IsClicked ? "bg-emerald-500" : "bg-slate-300")"></div>
                                <div>
                                    <p class="font-data-tabular text-primary font-semibold text-sm">@item.Timestamp.ToString("dd.MM.yyyy HH:mm:ss")</p>
                                    <p class="text-[10px] font-bold text-slate-400 uppercase">LOG ID: #@item.ImpressionID</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-lg py-4">
                            <div class="flex flex-col">
                                <span class="text-xs font-bold text-slate-700">@item.CampaignName</span>
                                <span class="text-[10px] text-slate-400">Yayıncı: @item.PublisherName</span>
                            </div>
                        </td>
                        <td class="px-lg py-4 text-center">
                            <span class="px-3 py-1 rounded-full bg-slate-100 text-slate-600 text-[10px] font-black border border-slate-200">
                                @item.RegionName
                            </span>
                        </td>
                        <td class="px-lg py-4 text-right">
                            <p class="font-data-tabular text-sm font-bold text-[#332A1C]">₺@item.CostPerClick.ToString("N2")</p>
                            @if (item.IsClicked)
                            {
                                <span class="text-[9px] bg-emerald-50 text-emerald-700 px-1.5 py-0.5 rounded border border-emerald-100 font-black uppercase tracking-tighter">Tıklama</span>
                            }
                            else
                            {
                                <span class="text-[9px] bg-slate-50 text-slate-400 px-1.5 py-0.5 rounded border border-slate-100 font-bold uppercase tracking-tighter">Gösterim</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="px-lg py-4 flex justify-between items-center border-t border-slate-100 bg-slate-50/50">
        <div class="flex items-center gap-4">
            <p class="text-[11px] text-slate-500 font-medium">
                Toplam <span class="text-primary font-bold">@ViewBag.TotalCount.ToString("N0")</span> kayıt.
            </p>
        </div>
        
        <div class="flex items-center gap-1">
            @{
                var routeData = new
                {
                    regionId = ViewBag.SelectedRegion,
                    isClicked = ViewBag.SelectedStatus,
                    campaignId = ViewBag.SelectedCampaign,
                    publisherId = ViewBag.SelectedPublisher
                };
            }

            <a href="@Url.Action("AdImpressionList", new { pageNumber = ViewBag.CurrentPage - 1, regionId = routeData.regionId, isClicked = routeData.isClicked, campaignId = routeData.campaignId, publisherId = routeData.publisherId })"
                   class="p-1.5 text-slate-400 hover:text-primary transition-colors border border-slate-200 bg-white rounded shadow-sm @(ViewBag.CurrentPage == 1 ? "pointer-events-none opacity-30" : "")">
                <span class="material-symbols-outlined text-sm">chevron_left</span>
            </a>

            <div class="flex gap-1 px-2">
                @for (int i = Math.Max(1, ViewBag.CurrentPage - 2); i <= Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2); i++)
                {
                    <a href="@Url.Action("AdImpressionList", new { pageNumber = i, regionId = routeData.regionId, isClicked = routeData.isClicked, campaignId = routeData.campaignId, publisherId = routeData.publisherId })"
                           class="text-[11px] font-bold px-3 py-1 rounded shadow-sm border transition-all @(i == ViewBag.CurrentPage ? "bg-[#332A1C] text-white border-[#332A1C]" : "bg-white border-slate-200 text-slate-600 hover:bg-slate-50")">
                        @i
                    </a>
                }
            </div>

            <a href="@Url.Action("AdImpressionList", new { pageNumber = ViewBag.CurrentPage + 1, regionId = routeData.regionId, isClicked = routeData.isClicked, campaignId = routeData.campaignId, publisherId = routeData.publisherId })"
                   class="p-1.5 text-slate-400 hover:text-primary transition-colors border border-slate-200 bg-white rounded shadow-sm @(ViewBag.CurrentPage == ViewBag.TotalPages ? "pointer-events-none opacity-30" : "")">
                <span class="material-symbols-outlined text-sm">chevron_right</span>
            </a>
        </div>
    </div>
</div>