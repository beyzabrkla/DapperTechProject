@model CreateCampaignDTO
@{
    ViewData["Title"] = "Kampanya Formu";
    Layout = "_Layout";
}

<div class="max-w-[800px] mx-auto space-y-md">
    <div class="flex justify-between items-center mb-xl">
        <div>
            <h1 class="font-h1 text-h1 text-on-surface">Yeni Kampanya Ekle</h1>
            <p class="font-body-md text-body-md text-on-surface-variant">Reklam ağları ve bütçe detaylarını buradan yönetebilirsiniz.</p>
        </div>
        <a asp-action="Index" class="flex items-center gap-2 px-md py-2 border border-outline-variant bg-white text-on-surface hover:bg-surface-container transition-colors rounded text-sm">
            <span class="material-symbols-outlined text-[18px]">arrow_back</span> Listeye Dön
        </a>
    </div>

    <form class="bg-white border border-outline-variant rounded shadow-sm overflow-hidden">
        <div class="p-xl space-y-lg">
            
            <div class="space-y-md">
                <h3 class="font-label-caps text-label-caps text-on-tertiary-fixed-variant border-b border-surface-container pb-2 uppercase tracking-widest text-[10px]">Genel Bilgiler</h3>
                
                <div class="grid grid-cols-1 gap-md">
                    <div class="space-y-1">
                        <label class="font-body-sm text-on-surface font-semibold">Kampanya Adı</label>
                        <input type="text" placeholder="Örn: 2024 Yaz İndirimi" class="w-full border-outline-variant rounded font-body-sm h-11 px-4 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all">
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
                    <div class="space-y-1">
                        <label class="font-body-sm text-on-surface font-semibold">Reklam Türü</label>
                        <select class="w-full border-outline-variant rounded font-body-sm h-11 px-4 focus:ring-2 focus:ring-primary focus:border-primary outline-none">
                            <option>Arama Ağı</option>
                            <option>Görüntülü Reklam</option>
                            <option>Video</option>
                            <option>Sosyal Medya</option>
                        </select>
                    </div>
                    <div class="space-y-1">
                        <label class="font-body-sm text-on-surface font-semibold">Hedef Bölge</label>
                        <select class="w-full border-outline-variant rounded font-body-sm h-11 px-4 focus:ring-2 focus:ring-primary focus:border-primary outline-none">
                            <option>Türkiye</option>
                            <option>Avrupa</option>
                            <option>Global</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="space-y-md pt-4">
                <h3 class="font-label-caps text-label-caps text-on-tertiary-fixed-variant border-b border-surface-container pb-2 uppercase tracking-widest text-[10px]">Bütçe ve Planlama</h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
                    <div class="space-y-1">
                        <label class="font-body-sm text-on-surface font-semibold">Toplam Bütçe (₺)</label>
                        <div class="relative">
                            <input type="number" placeholder="0.00" class="w-full border-outline-variant rounded font-body-sm h-11 pl-10 pr-4 focus:ring-2 focus:ring-primary focus:border-primary outline-none">
                            <span class="absolute left-4 top-3 text-slate-400 font-bold text-sm">₺</span>
                        </div>
                    </div>
                    <div class="space-y-1">
                        <label class="font-body-sm text-on-surface font-semibold">Durum</label>
                        <select class="w-full border-outline-variant rounded font-body-sm h-11 px-4 focus:ring-2 focus:ring-primary focus:border-primary outline-none">
                            <option>Yayında</option>
                            <option>Beklemede</option>
                            <option>Durduruldu</option>
                        </select>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
                    <div class="space-y-1">
                        <label class="font-body-sm text-on-surface font-semibold">Başlangıç Tarihi</label>
                        <input type="date" class="w-full border-outline-variant rounded font-body-sm h-11 px-4 focus:ring-2 focus:ring-primary focus:border-primary outline-none">
                    </div>
                    <div class="space-y-1">
                        <label class="font-body-sm text-on-surface font-semibold">Bitiş Tarihi</label>
                        <input type="date" class="w-full border-outline-variant rounded font-body-sm h-11 px-4 focus:ring-2 focus:ring-primary focus:border-primary outline-none">
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-surface-container px-xl py-6 flex justify-end gap-3 border-t border-outline-variant">
            <button type="reset" class="px-6 py-2.5 font-bold text-xs uppercase tracking-widest text-slate-500 hover:text-slate-800 transition-colors">Formu Temizle</button>
            <button type="submit" class="bg-primary text-white px-8 py-2.5 rounded font-bold text-xs uppercase tracking-widest hover:bg-primary-container transition-all flex items-center gap-2 shadow-sm">
                <span class="material-symbols-outlined text-[18px]">check_circle</span> Kaydet ve Yayınla
            </button>
        </div>
    </form>

    <div class="flex items-start gap-3 p-4 bg-primary-fixed rounded border border-outline-variant opacity-80">
        <span class="material-symbols-outlined text-on-primary-fixed-variant">info</span>
        <p class="text-[11px] text-on-primary-fixed-variant leading-relaxed">
            <strong>Not:</strong> Kampanya bilgilerini güncellediğinizde reklam ağlarındaki senkronizasyon yaklaşık 5 dakika sürebilir. Bütçe değişiklikleri anında yansıtılır.
        </p>
    </div>
</div>