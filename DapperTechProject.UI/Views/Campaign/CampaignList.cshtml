@using DapperTechProject.DTOLayer.RegionDTOs
@using DapperTechProject.DTOLayer.CampaignTypeDTOs
@model List<ResultCampaignDTO>
@{
    ViewData["Title"] = "Kampanya Yönetimi";
    Layout = "_Layout";
}

<div class="max-w-container-max mx-auto space-y-md">
    <div class="flex justify-between items-end mb-xl">
        <div>
            <h1 class="font-h1 text-h1 text-on-surface">Kampanya Yönetimi</h1>
            <p class="font-body-md text-body-md text-on-surface-variant">Aktif reklam kampanyalarınızı yönetin ve optimize edin.</p>
        </div>
        <div class="flex gap-sm">
            <a href="/Campaign/CreateCampaign" class="flex items-center gap-2 px-md py-2 bg-primary text-white rounded text-sm hover:bg-primary-container transition-colors">
                <span class="material-symbols-outlined text-[18px]">add</span> Yeni Kampanya
            </a>
        </div>
    </div>

    <form method="get" asp-action="CampaignList" asp-controller="Campaign" class="bg-white border border-outline-variant rounded shadow-sm p-md">
        <div class="flex items-center gap-sm mb-md pb-sm border-b border-surface-container">
            <span class="material-symbols-outlined text-on-tertiary-container">filter_list</span>
            <span class="font-label-caps text-label-caps text-on-surface-variant">GELİŞMİŞ FİLTRELEME</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-md items-end">
            <div class="space-y-1">
                <label class="font-label-caps text-on-surface-variant block uppercase text-[10px]">Arama (İsim/Müşteri)</label>
                <input type="text" name="search" value="@ViewBag.CurrentSearch" placeholder="Ara..." class="w-full border-outline-variant rounded font-body-sm text-body-sm h-10 px-3 focus:ring-2 focus:ring-primary" />
            </div>
            
            <div class="space-y-1">
                <label class="font-label-caps text-on-surface-variant block uppercase text-[10px]">Ülke / Bölge</label>
                <select name="region" class="w-full border-outline-variant rounded font-body-sm text-body-sm h-10 px-3 focus:ring-2 focus:ring-primary">
                    <option value="">Tüm Bölgeler</option>
                    @foreach (var r in ViewBag.Regions as List<ResultRegionDTO>)
                    {
                        <option value="@r.RegionName" selected='@(ViewBag.CurrentRegion == r.RegionName)'>@r.RegionName</option>
                    }
                </select>
            </div>

            <div class="space-y-1">
                <label class="font-label-caps text-on-surface-variant block uppercase text-[10px]">Kampanya Türü</label>
                <select name="type" class="w-full border-outline-variant rounded font-body-sm text-body-sm h-10 px-3 focus:ring-2 focus:ring-primary">
                    <option value="">Tüm Kampanyalar</option>
                    @foreach (var t in ViewBag.Types as List<ResultCampaignTypeDTO>)
                    {
                        <option value="@t.TypeName" selected='@(ViewBag.CurrentType == t.TypeName)'>@t.TypeName</option>
                    }
                </select>
            </div>

            <div class="flex gap-2">
                <button type="submit" class="flex-1 h-10 bg-tertiary text-white font-data-tabular rounded hover:bg-tertiary-container transition-colors text-sm font-semibold">Filtrele</button>
                <a href="/Campaign/CampaignList" class="h-10 px-3 border border-outline-variant text-on-surface hover:bg-surface-container rounded transition-colors flex items-center">
                    <span class="material-symbols-outlined">restart_alt</span>
                </a>
            </div>
        </div>
    </form>

    <div class="bg-white border border-outline-variant rounded shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-container border-b border-outline-variant">
                        <th class="px-md py-3 font-label-caps text-on-surface-variant uppercase text-[10px]">ID</th>
                        <th class="px-md py-3 font-label-caps text-on-surface-variant uppercase text-[10px]">Kampanya Detayı</th>
                        <th class="px-md py-3 font-label-caps text-on-surface-variant uppercase text-[10px]">Oluşturulma</th>
                        <th class="px-md py-3 font-label-caps text-on-surface-variant uppercase text-right text-[10px]">Bütçe</th>
                        <th class="px-md py-3 font-label-caps text-on-surface-variant uppercase text-right text-[10px]">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-surface-container">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-surface-container-low transition-colors">
                            <td class="px-md py-3 font-data-tabular text-on-tertiary-fixed-variant text-xs">#@item.CampaignID</td>
                            <td class="px-md py-3">
                                <div class="font-body-md font-semibold text-on-surface">@item.CampaignName</div>
                                <div class="font-body-sm text-on-surface-variant">@item.ClientName • @item.RegionName • @item.TypeName</div>
                            </td>
                            <td class="px-md py-3 font-data-tabular text-xs">@item.CreatedDate.ToString("dd MMM yyyy")</td>
                            <td class="px-md py-3 font-data-tabular text-right text-xs font-bold">@item.Budget?.ToString("N2") ₺</td>
                            <td class="px-md py-3 text-right">
                                <div class="flex justify-end gap-1">
                                    <a href="/Campaign/UpdateCampaign/@item.CampaignID" class="p-1.5 hover:bg-surface-container-high rounded text-on-surface-variant"><span class="material-symbols-outlined">edit</span></a>
                                    <a href="/Campaign/DeleteCampaign/@item.CampaignID" onclick="return confirm('Silmek istediğine emin misin?')" class="p-1.5 hover:bg-error-container hover:text-on-error-container rounded text-on-surface-variant"><span class="material-symbols-outlined">delete</span></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div class="px-md py-3 border-t border-outline-variant bg-surface-container-low flex justify-between items-center">
            <span class="font-body-sm text-on-surface-variant">Toplam <b>@ViewBag.TotalCount</b> kampanya listeleniyor.</span>
            <div class="flex gap-1">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a href="@Url.Action("CampaignList", new { page = i, search = ViewBag.CurrentSearch, region = ViewBag.CurrentRegion, type = ViewBag.CurrentType })"
                           class="w-8 h-8 flex items-center justify-center border rounded font-data-tabular text-xs @(i == ViewBag.CurrentPage ? "border-primary bg-primary text-white" : "border-outline-variant hover:bg-surface-container")">
                        @i
                    </a>
                }
            </div>
        </div>
    </div>
</div>