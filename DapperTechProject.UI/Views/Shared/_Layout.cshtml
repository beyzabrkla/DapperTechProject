<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Ad-Tech Pro</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
  "colors": {
                        "on-tertiary-container": "#8b90b5",
                        "error-container": "#ffdad6",
                        "surface-tint": "#685d4c",
                        "on-tertiary-fixed": "#141937",
                        "surface-container-highest": "#e2e2e2",
                        "on-secondary-container": "#4c6972",
                        "secondary-fixed": "#c8e8f2",
                        "on-secondary": "#ffffff",
                        "surface-container-high": "#e8e8e8",
                        "surface-variant": "#e2e2e2",
                        "on-primary": "#ffffff",
                        "inverse-primary": "#d4c4b0",
                        "outline-variant": "#cfc5ba",
                        "on-surface": "#1a1c1c",
                        "on-error": "#ffffff",
                        "inverse-surface": "#2f3131",
                        "inverse-on-surface": "#f1f1f1",
                        "secondary-container": "#c8e8f2",
                        "surface-container-lowest": "#ffffff",
                        "primary-fixed": "#f1e0cb",
                        "surface-dim": "#dadada",
                        "surface-container-low": "#f3f3f3",
                        "surface": "#f9f9f9",
                        "primary-container": "#332a1c",
                        "background": "#f9f9f9",
                        "on-primary-fixed-variant": "#504536",
                        "secondary": "#46636c",
                        "primary": "#1d1609",
                        "on-background": "#1a1c1c",
                        "secondary-fixed-dim": "#adccd6",
                        "on-primary-fixed": "#221a0d",
                        "tertiary-fixed": "#dee0ff",
                        "on-primary-container": "#9e917e",
                        "on-error-container": "#93000a",
                        "surface-bright": "#f9f9f9",
                        "on-tertiary-fixed-variant": "#404565",
                        "primary-fixed-dim": "#d4c4b0",
                        "on-surface-variant": "#4c463e",
                        "surface-container": "#eeeeee",
                        "tertiary-container": "#242948",
                        "on-secondary-fixed-variant": "#2e4b53",
                        "tertiary-fixed-dim": "#c0c4eb",
                        "tertiary": "#0f1432",
                        "on-secondary-fixed": "#001f26",
                        "outline": "#7d766d",
                        "on-tertiary": "#ffffff",
                        "error": "#ba1a1a"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "spacing": {
                        "lg": "24px",
                        "sidebar-width": "260px",
                        "md": "16px",
                        "base": "4px",
                        "container-max": "1600px",
                        "sm": "8px",
                        "gutter": "16px",
                        "xl": "32px",
                        "xs": "4px"
                    },
                    "fontFamily": {
                        "data-tabular": ["Inter"],
                        "body-md": ["Inter"],
                        "h2": ["Inter"],
                        "body-sm": ["Inter"],
                        "label-caps": ["Inter"],
                        "h1": ["Inter"],
                        "body-lg": ["Inter"]
                    },
                    "fontSize": {
                        "data-tabular": ["13px", {"lineHeight": "18px", "fontWeight": "500"}],
                        "body-md": ["14px", {"lineHeight": "20px", "fontWeight": "400"}],
                        "h2": ["20px", {"lineHeight": "28px", "letterSpacing": "-0.01em", "fontWeight": "600"}],
                        "body-sm": ["12px", {"lineHeight": "16px", "fontWeight": "400"}],
                        "label-caps": ["11px", {"lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "700"}],
                        "h1": ["24px", {"lineHeight": "32px", "letterSpacing": "-0.02em", "fontWeight": "600"}],
                        "body-lg": ["16px", {"lineHeight": "24px", "fontWeight": "400"}]
                    }
        }
        }
        }
    </script>

    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 20; font-size: 20px; }
        body { background-color: #f9f9f9; }
    </style>
</head>

<body class="font-body-md text-on-surface">

    @await Component.InvokeAsync("Sidebar")

    @await Component.InvokeAsync("Navbar")

    <main class="ml-[260px] pt-20 px-6 pb-6 max-w-[1600px]">
        @RenderBody()
    </main>
    @RenderSection("Scripts", required: false)
</body>
</html>