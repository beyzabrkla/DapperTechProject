@using DapperTechProject.DTOLayer.CampaignDTOs
@model List<ResultCampaignDTO>

@{
    ViewData["Title"] = "Analiz Paneli";
    Layout = "_Layout";
}

<section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-white p-6 border border-slate-200 shadow-sm hover:shadow-md transition-all rounded-lg">
        <div class="flex justify-between items-start mb-4">
            <span class="text-[11px] font-bold tracking-wider text-slate-500 uppercase">TOPLAM GÖSTERİM</span>
            <span class="text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded text-[10px] font-bold">+12%</span>
        </div>
        <h2 class="text-3xl font-bold text-slate-900">@ViewBag.TotalImpressions</h2>
        <div class="mt-6 h-1 w-full bg-slate-100 rounded-full overflow-hidden">
            <div class="h-full bg-slate-900" style="width: 72%;"></div>
        </div>
    </div>

    <div class="bg-white p-6 border border-slate-200 shadow-sm rounded-lg">
        <div class="flex justify-between items-start mb-4">
            <span class="text-[11px] font-bold tracking-wider text-slate-500 uppercase">REKLAM TIKLAMALARI</span>
            <span class="text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded text-[10px] font-bold">+4.2%</span>
        </div>
        <h2 class="text-3xl font-bold text-slate-900">@ViewBag.TotalClicks</h2>
        <div class="mt-6 flex items-end gap-1 h-2">
            <div class="flex-1 bg-slate-200 h-[40%]"></div>
            <div class="flex-1 bg-slate-300 h-[70%]"></div>
            <div class="flex-1 bg-slate-900 h-[100%]"></div>
        </div>
    </div>

    <div class="bg-white p-6 border border-slate-200 shadow-sm rounded-lg">
        <div class="flex justify-between items-start mb-4">
            <span class="text-[11px] font-bold tracking-wider text-slate-500 uppercase">TIKLAMA ORANI (CTR)</span>
            <span class="text-slate-500 bg-slate-50 px-2 py-0.5 rounded text-[10px] font-bold">Verim</span>
        </div>
        <h2 class="text-3xl font-bold text-slate-900">%@ViewBag.CTR</h2>
        <p class="text-[10px] text-slate-400 mt-4 italic">Aktif Kampanya: @ViewBag.CampaignCount</p>
    </div>

    <div class="bg-white p-6 border border-slate-200 shadow-sm rounded-lg border-l-4 border-l-slate-900">
        <div class="flex justify-between items-start mb-4">
            <span class="text-[11px] font-bold tracking-wider text-slate-500 uppercase">ORT. TIKLAMA MALİYETİ</span>
            <span class="material-symbols-outlined text-slate-400 text-sm">payments</span>
        </div>
        <h2 class="text-3xl font-bold text-slate-900">@ViewBag.AvgCPC</h2>
        <p class="text-[10px] text-slate-400 mt-4 italic">Kategori Sayısı: @ViewBag.CategoryCount</p>
    </div>
</section>

<section class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-8">
    <div class="lg:col-span-7 bg-white border border-slate-200 p-6 rounded-lg shadow-sm">
        <h3 class="text-sm font-bold text-slate-900 mb-6 uppercase tracking-widest">En Çok Harcama Yapan Kampanyalar (₺)</h3>
        <div class="h-[300px]">
            <canvas id="spendingChart"></canvas>
        </div>
    </div>

    <div class="lg:col-span-5 bg-white border border-slate-200 p-6 rounded-lg shadow-sm">
        <h3 class="text-sm font-bold text-slate-900 mb-6 uppercase tracking-widest">Bölgesel Tıklama Dağılımı</h3>
        <div class="h-[300px]">
            <canvas id="regionChart"></canvas>
        </div>
    </div>
</section>

<section class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-8">
    <div class="lg:col-span-5 bg-white border border-slate-200 p-6 rounded-lg shadow-sm">
        <h3 class="text-sm font-bold text-slate-900 mb-6 uppercase tracking-widest">Sektörel Gösterim Dağılımı</h3>
        <div class="h-[350px]">
            <canvas id="categoryRadarChart"></canvas>
        </div>
    </div>

    <div class="lg:col-span-7 bg-white border border-slate-200 p-6 rounded-lg shadow-sm">
        <h3 class="text-sm font-bold text-slate-900 mb-6 uppercase tracking-widest">En Uygun Maliyetli Yayıncılar (Avg. CPC)</h3>
        <div class="h-[350px]">
            <canvas id="publisherEffChart"></canvas>
        </div>
    </div>
</section>

<section class="bg-white border border-slate-200 shadow-sm rounded-lg overflow-hidden">
    <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
        <h3 class="text-lg font-bold text-slate-900">Son Aktif Kampanyalar</h3>
        <a href="/Campaign/Index" class="text-xs font-bold text-slate-500 hover:text-slate-900 transition-colors uppercase tracking-tighter">Tümünü Yönet →</a>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50">
                    <th class="px-6 py-4 text-[10px] font-bold text-slate-400 uppercase tracking-wider">Kampanya & Bölge</th>
                    <th class="px-6 py-4 text-[10px] font-bold text-slate-400 uppercase tracking-wider">Müşteri</th>
                    <th class="px-6 py-4 text-[10px] font-bold text-slate-400 uppercase tracking-wider text-right">Bütçe</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4">
                            <div class="text-sm font-bold text-slate-900">@item.CampaignName</div>
                            <div class="text-[10px] text-slate-400 font-medium">@item.RegionName</div>
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-600">@item.ClientName</td>
                        <td class="px-6 py-4 text-right font-bold text-slate-800 text-sm">
                            ₺@item.Budget?.ToString("N2")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // 1. Harcama Analizi (Bar)
        new Chart(document.getElementById('spendingChart'), {
        type: 'bar',
        data: {
        labels: @Html.Raw(Json.Serialize(ViewBag.TopCampaignLabels)),
        datasets: [{
        label: 'Toplam Harcama (₺)',
        data: @Html.Raw(Json.Serialize(ViewBag.TopCampaignSpends)),
        backgroundColor: '#1e293b',
        borderRadius: 6
        }]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
        });

        // 2. Bölge Analizi (Doughnut)
        new Chart(document.getElementById('regionChart'), {
        type: 'doughnut',
        data: {
        labels: @Html.Raw(Json.Serialize(ViewBag.RegionLabels)),
        datasets: [{
        data: @Html.Raw(Json.Serialize(ViewBag.RegionClickData)),
        backgroundColor: ['#0f172a', '#334155', '#64748b', '#94a3b8', '#cbd5e1'],
        borderWidth: 4,
        borderColor: '#ffffff'
        }]
        },
        options: { cutout: '75%', responsive: true, maintainAspectRatio: false }
        });

        // 3. Kategori Radar Chart
        new Chart(document.getElementById('categoryRadarChart'), {
        type: 'radar',
        data: {
        labels: @Html.Raw(Json.Serialize(ViewBag.CatLabels)),
        datasets: [{
        label: 'Gösterim Hacmi',
        data: @Html.Raw(Json.Serialize(ViewBag.CatData)),
        backgroundColor: 'rgba(15, 23, 42, 0.1)',
        borderColor: '#0f172a',
        pointBackgroundColor: '#0f172a'
        }]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
        });

        // 4. Yayıncı Verimliliği (Horizontal Bar)
        new Chart(document.getElementById('publisherEffChart'), {
        type: 'bar',
        data: {
        labels: @Html.Raw(Json.Serialize(ViewBag.PubLabels)),
        datasets: [{
        label: 'Ort. CPC (₺)',
        data: @Html.Raw(Json.Serialize(ViewBag.PubEfficiency)),
        backgroundColor: '#475569',
        borderRadius: 4
        }]
        },
        options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } }
        }
        });
    </script>
}